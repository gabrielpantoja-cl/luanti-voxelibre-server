# Directorios de datos del servidor
server/worlds/*
!server/worlds/*/auth.txt
server/backups/*
server/config/ban.txt

# Logs
*.log
debug.txt

# Docker y configuración local
.env
.env.local

# Claude Code configuración local (personal, no compartida)
.claude/settings.local.json
.claude/*.lock
CLAUDE.local.md

# Sistema
.DS_Store
Thumbs.db

# Temporales
*.tmp
*.swp
*~
salida_ogg/
otras-texturas/

# Herramientas de testing/MCP (cache local)
.playwright-mcp/

# Screenshots temporales en raiz
/*.png
/*.jpg
/*.jpeg

# Secrets (por si acaso)
secrets/
*.key
*.pem

# Mantener directorios pero ignorar contenido
!server/worlds/.gitkeep
!server/backups/.gitkeep

# Backups grandes (excluir de Git)
world-snapshots/*.tar.gz
server/worlds/world/
server/worlds_archive/

# Valdivia world data (generado por Arnis, muy grande para git)
server/worlds/valdivia/map.sqlite
server/worlds/valdivia/auth.sqlite
server/worlds/valdivia/players.sqlite
server/worlds/valdivia/mod_storage.sqlite
