server/worlds/valdivia/force_loaded.txt
server/worlds/valdivia/ipban.txt
server/worlds/valdivia/map_meta.txt

# GAELSIN world data (generado desde seed, regenerable via reset-gaelsin.sh)
server/worlds/gaelsin/
server/worlds/gaelsin_DESTROYED_*/

