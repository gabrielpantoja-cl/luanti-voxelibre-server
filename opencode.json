{
  "$schema": "https://opencode.ai/config.json",
  "model": "minimax-coding-plan/MiniMax-M3",
  "enabled_providers": ["minimax-coding-plan"],
  "instructions": [
    "AGENTS.md",
    "AGENTS.local.md"
  ],
  "permission": {
    "external_directory": "ask",
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 12000
  },
  "snapshot": true,
  "share": "manual",
  "autoupdate": "notify"
}
