# =============================================
# CONFIGURACIÓN VPS - WETLANDS
# =============================================
# Este archivo contiene las variables de entorno necesarias para el despliegue
# Copia este archivo como .env.local y completa los valores reales

# Información del VPS Digital Ocean
VPS_HOST=<IP_VPS_ANTERIOR>
VPS_USER=gabriel
VPS_SSH_KEY_PATH=~/.ssh/id_rsa
VPS_PORT=22

# Dominio principal y subdominios
DOMAIN_ROOT=gabrielpantoja.cl
LUANTI_SUBDOMAIN=luanti.gabrielpantoja.cl

# Configuración del servidor Luanti
LUANTI_PORT=30000
LUANTI_WORLD_NAME=world
LUANTI_SERVER_NAME="Wetlands | Servidor Creativo y Educativo"
LUANTI_MAX_USERS=20

# Configuración de backups
BACKUP_FREQUENCY="0 */6 * * *"  # Cada 6 horas
BACKUP_RETENTION_DAYS=7
WEBHOOK_URL=""  # URL para notificaciones (Discord/n8n)

# GitHub Secrets requeridos para CI/CD
# Configura estos en GitHub → Settings → Secrets and variables → Actions:
# - VPS_HOST (usar valor de VPS_HOST arriba)
# - VPS_USER (usar valor de VPS_USER arriba)  
# - VPS_SSH_KEY (contenido completo de la clave privada SSH)
# - VPS_PORT (usar valor de VPS_PORT arriba)

# Configuración de red
FIREWALL_PORTS=22,80,443,30000/udp

# Configuración de zona horaria
TZ="America/Santiago"

# Monitoreo opcional
ENABLE_MONITORING=false
PROMETHEUS_RETENTION=15d
GRAFANA_ADMIN_PASSWORD=change_me_secure_password